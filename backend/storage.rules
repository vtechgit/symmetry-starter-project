rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Article thumbnails stored under media/articles/
    match /media/articles/{imageFile} {

      // Anyone can read article thumbnails — URLs are embedded in the public feed
      allow read: if true;

      // Only allow image uploads under 5 MB with a valid image content type
      allow write: if request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }
  }
}
