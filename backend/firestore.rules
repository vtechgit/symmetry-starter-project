rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /articles/{articleId} {

      // Anyone can read articles — this is a public news feed
      allow read: if true;

      // Journalists can create an article only if it passes schema validation
      allow create: if isValidArticle(request.resource.data);

      // Updates must keep all required fields valid
      allow update: if isValidArticle(request.resource.data);

      // Allow deletion without restrictions for now
      allow delete: if true;
    }

    // Validates that a document has all required fields with the correct types.
    // This enforces the schema defined in backend/docs/DB_SCHEMA.md.
    function isValidArticle(article) {
      return article.title is string        && article.title.size() > 0
          && article.author is string       && article.author.size() > 0
          && article.description is string  && article.description.size() > 0
          && article.content is string      && article.content.size() > 0
          && article.thumbnailURL is string && article.thumbnailURL.size() > 0
          && article.publishedAt is timestamp
          && article.createdAt is timestamp;
    }
  }
}
