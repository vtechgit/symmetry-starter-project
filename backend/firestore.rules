rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /articles/{articleId} {
      allow read: if true;

      allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && isValidArticle(request.resource.data);

      allow update: if request.auth != null
          && (
            resource.data.get('authorId', null) == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['likeCount', 'commentCount'])
          );

      allow delete: if request.auth != null
          && resource.data.get('authorId', null) == request.auth.uid;

      match /likes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0;
        allow delete: if request.auth != null
            && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }

    match /users/{uid}/bookmarks/{articleId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    function isValidArticle(d) {
      return d.title is string && d.title.size() > 0
          && d.author is string && d.author.size() > 0
          && d.description is string && d.description.size() > 0
          && d.content is string && d.content.size() > 0
          && d.thumbnailURL is string && d.thumbnailURL.size() > 0
          && d.authorId is string && d.authorId.size() > 0
          && d.publishedAt is timestamp
          && d.createdAt is timestamp;
    }
  }
}
